# Rental Services Backend - Environment Configuration Example
# Copy this file to .env and update values for your environment

# ============================================
# MongoDB Configuration
# ============================================
# For Local MongoDB:
MONGODB_URI = mongodb+srv://bhuvneshvashishth925:vashishth%40123@cluster0.wcdxkpa.mongodb.net/
# For MongoDB Atlas (Cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster-name.mongodb.net/rental-services?retryWrites=true&w=majority

# ============================================
# JWT Configuration
# ============================================
# Change this to a strong random string in production
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_12345

# Token expiration time
JWT_EXPIRE=7d

# ============================================
# Server Configuration
# ============================================
# Port to run the server on
PORT=5001

# Node environment (development, production, test)
NODE_ENV=development

# ============================================
# CORS Configuration
# ============================================
# Frontend URL - Update according to your frontend
CLIENT_URL=http://localhost:5173

# ============================================
# Logging (Optional)
# ============================================
DEBUG=rental-services:*
